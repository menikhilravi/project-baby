# Supabase — Project Settings → API
# Copy to .env.local and fill in values from your Supabase project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never exposed to the browser. Used by privileged server actions.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret Vercel Cron sends as Authorization: Bearer <this>.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Gemini — for NB-4 LLM name generation
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
